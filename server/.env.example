# AWS Credentials (Required) — Get from IAM Console
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# AWS Region (Optional, default: us-east-1)
AWS_REGION=us-east-1

# Bedrock Model ID (Optional, default: amazon.titan-text-express-v1)
# Options: amazon.titan-text-express-v1, amazon.titan-text-premier-v1:0,
#          anthropic.claude-3-haiku-20240307-v1:0, meta.llama3-8b-instruct-v1:0
BEDROCK_MODEL_ID=amazon.titan-text-express-v1

# Server Port (Optional, default: 3001)
PORT=3001
